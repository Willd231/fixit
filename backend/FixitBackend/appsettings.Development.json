{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=fixit-dev.db;"
  },
  "JwtSettings": {
    "SecretKey": "dev-secret-key-for-testing-only-minimum-32-characters-long!",
    "Issuer": "FixIt",
    "Audience": "FixItClient",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174",
      "http://localhost:3000"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "Microsoft.EntityFrameworkCore": "Debug",
      "Microsoft.AspNetCore.Authentication": "Debug"
    }
  }
}
