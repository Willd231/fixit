{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=fixit.db;"
  },
  "JwtSettings": {
    "SecretKey": "your-secret-key-change-this-in-production-minimum-32-characters-long!",
    "Issuer": "FixIt",
    "Audience": "FixItClient",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174",
      "http://localhost:3000"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*"
}
